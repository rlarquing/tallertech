# ============================================================
# TallerTech Environment Variables
# ============================================================

# Database - LOCAL DEVELOPMENT (SQLite file)
DATABASE_URL=file:./db/custom.db

# Database - TURSO (libSQL) - Set these for production/Vercel
# When using Turso, set DATABASE_URL to the libsql:// URL
# and DATABASE_AUTH_TOKEN to your Turso auth token
# Get these from: https://turso.tech/app
# DATABASE_URL=libsql://your-db-name-your-org.turso.io
# DATABASE_AUTH_TOKEN=your-auth-token-here
