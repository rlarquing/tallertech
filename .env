# ============================================================
# Database Configuration - Turso / Local SQLite
# ============================================================
# For LOCAL development (SQLite file):
DATABASE_URL=file:/home/z/my-project/db/custom.db

# For TURSO cloud (uncomment and fill in your credentials):
# DATABASE_URL=libsql://your-db-name-your-org.turso.io?tls=1
# DATABASE_AUTH_TOKEN=your-auth-token-here

# Turso-specific env vars (used by prisma.config.ts and prisma-client.ts)
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io?tls=1
# TURSO_AUTH_TOKEN=your-auth-token-here
